{
  "name": "digittron-server",
  "version": "1.0.0",
  "description": "web server for digittron",
  "main": "server.js",
  "scripts": {
		"client:astro": "cd panel && node_modules/.bin/astro",
		"client:build": "cd panel && node_modules/.bin/astro build",
		"client:dev": "cd panel && node_modules/.bin/astro dev",
		"client:preview": "cd panel && node_modules/.bin/astro preview",
		"client:start": "cd panel && node_modules/.bin/astro dev",
    "build": "tsc -p server/src/tsconfig.json",
    "start": "node server/dist/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/secondubly/digittron-server.git"
  },
  "author": "secondubly",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/secondubly/digittron-server/issues"
  },
  "homepage": "https://github.com/secondubly/digittron-server#readme",
  "dependencies": {
    "@fastify/oauth2": "^7.5.0",
    "fastify": "^4.24.3"
  },
  "devDependencies": {
    "@types/node": "^20.8.7",
    "typescript": "^5.2.2"
  }
}