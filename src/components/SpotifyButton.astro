---
import crypto from 'crypto'
const { state = crypto.randomBytes(32).toString('hex') } = Astro.props

Astro.cookies.set('spotify_oauth_state', state, {
    httpOnly: true,
    secure: !import.meta.env.DEV,
    path: "/",
    maxAge: 60 * 60 // 1 hour
})
---
<spotify-oauth-button data-state={state}>
    <button type="button" class="text-white bg-[#1DB954] 
    focus:ring-4 focus:outline-none focus:ring-blue-300 
    font-medium rounded-lg text-sm px-5 py-2.5 text-center inline-flex items-center me-2 
    dark:focus:ring-blue-800">
    <svg class="me-2" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
        <path fill="currentColor" d="M17.9 10.9C14.7 9 9.35 8.8 6.3 9.75c-.5.15-1-.15-1.15-.6c-.15-.5.15-1 .6-1.15c3.55-1.05 9.4-.85 13.1 1.35c.45.25.6.85.35 1.3c-.25.35-.85.5-1.3.25m-.1 2.8c-.25.35-.7.5-1.05.25c-2.7-1.65-6.8-2.15-9.95-1.15c-.4.1-.85-.1-.95-.5c-.1-.4.1-.85.5-.95c3.65-1.1 8.15-.55 11.25 1.35c.3.15.45.65.2 1m-1.2 2.75c-.2.3-.55.4-.85.2c-2.35-1.45-5.3-1.75-8.8-.95c-.35.1-.65-.15-.75-.45c-.1-.35.15-.65.45-.75c3.8-.85 7.1-.5 9.7 1.1c.35.15.4.55.25.85M12 2A10 10 0 0 0 2 12a10 10 0 0 0 10 10a10 10 0 0 0 10-10A10 10 0 0 0 12 2"/>
    </svg>
        Connect with Spotify
    </button>
</twitch-oauth-button>

<script>
    import config from '../resources/oauth/scopes.json'
    let spotifyBaseUri = 'https://accounts.spotify.com/authorize'
    class SpotifyButton extends HTMLElement { 
        constructor() { 
        super()

        const state = this.dataset.state as string;
        const button = this.querySelector<HTMLElement>('button');
        if (!button) {
            throw new ReferenceError("Twitch Oauth Button not found.");
        }

        button.addEventListener('click', () => {
            const scopes = Object.keys(config.spotify).join(' ')
            const CLIENT_ID = import.meta.env.PUBLIC_SPOTIFY_CLIENT_ID
            const redirect_uri = `${window.location.origin}/spotify/callback`
            console.debug(redirect_uri)
            const params = new URLSearchParams({ response_type: 'code', client_id: CLIENT_ID, scope: scopes, show_dialog: 'true', state: state})

            const uri = `${spotifyBaseUri}?${params}&redirect_uri=${redirect_uri}`
            window.location.href=uri
        }); 
        } 
    }

    customElements.define('spotify-oauth-button', SpotifyButton)
</script>