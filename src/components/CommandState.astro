---
const { enabled } = Astro.props
---
<span style={ enabled ? 'display: none' : '' } class="
    focus:outline-none text-white bg-red-700 
    hover:bg-red-800 focus:ring-4 focus:ring-red-300 
    font-medium rounded-lg text-sm px-2 py-1.5 
    me-2 mb-2 dark:bg-red-600
    dark:hover:bg-red-700 dark:focus:ring-red-900">
    Disabled
</span>

<span 
    style={ !enabled ? 'display: none' : '' }
    class="
    text-white bg-green-700 hover:bg-green-800 
    focus:outline-none focus:ring-4 focus:ring-green-300 
    font-medium rounded text-xs px-2 py-1.5 
    text-center me-2 mb-2 dark:bg-green-600 
    dark:hover:bg-green-700 dark:focus:ring-green-800">
    Enabled
</span>