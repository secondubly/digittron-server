---
/* eslint max-lines: 'off' */
import ColorModeSwitch from './ColorModeSwitch.astro';

import { redis } from "../middleware"
import { getUserData } from "../pages/api/utils"
import type { User } from "ts-twitch-api"
import type { AccessToken } from '@twurple/auth';

let imageString: string | null = await redis.get('twitch_image') ?? null
if (!imageString) {
	const broadcasterId: string | null = await redis.get('twitch_broadcaster_id') ?? ''
	if (!broadcasterId) {
		throw new Error("Broadcaster ID not set, user should reauthenticate.")
	}

	let tokenJson = await redis.get(broadcasterId) ?? ''
	if (tokenJson === '') {
		console.warn("Broadcaster OAuth token not found, user should reauthenticate.")
		Astro.redirect('/setup')
		// TODO: add alert message when redirecting
	}
	const parsedToken: AccessToken = JSON.parse(tokenJson)

	let userData: User | null = await getUserData(parsedToken, broadcasterId)
	if (!userData) {
		throw Error('Could not fetch user data')
	}

    const response = await fetch(userData.profile_image_url)
    const blob  = await response.arrayBuffer()
    const contentType = response.headers.get('content-type')
    imageString = `data:${contentType};base64,${Buffer.from(blob).toString('base64')}`;
    redis.set('twitch_image', imageString)
}
---

<nav
	class="fixed z-30 w-full bg-white border-b border-gray-200 dark:bg-gray-800 dark:border-gray-700"
>
	<div class="px-3 py-3 lg:px-5 lg:pl-3">
		<div class="flex items-center justify-between">
			<div class="flex items-center justify-start">
				<button
					id="toggleSidebarMobile"
					aria-expanded="true"
					aria-controls="sidebar"
