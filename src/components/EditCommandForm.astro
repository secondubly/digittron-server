---
import '../styles/range-slider.css'
const { command } = Astro.props
import $Enums from '@prisma/client'
import { toTitleCase } from '../resources/utils'
const permissionEnums = Object.keys($Enums.PermissionLevel)
const formattedEnums = permissionEnums.map(toTitleCase)
---
<!-- Modal toggle -->
<button data-modal-target="edit-command-modal" data-modal-toggle="edit-command-modal"class="bg-orange-400 p-1 rounded">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24">
        <g fill="none">
            <path d="M24 0v24H0V0zM12.593 23.258l-.011.002l-.071.035l-.02.004l-.014-.004l-.071-.035c-.01-.004-.019-.001-.024.005l-.004.01l-.017.428l.005.02l.01.013l.104.074l.015.004l.012-.004l.104-.074l.012-.016l.004-.017l-.017-.427c-.002-.01-.009-.017-.017-.018m.265-.113l-.013.002l-.185.093l-.01.01l-.003.011l.018.43l.005.012l.008.007l.201.093c.012.004.023 0 .029-.008l.004-.014l-.034-.614c-.003-.012-.01-.02-.02-.022m-.715.002a.023.023 0 0 0-.027.006l-.006.014l-.034.614c0 .012.007.02.017.024l.015-.002l.201-.093l.01-.008l.004-.011l.017-.43l-.003-.012l-.01-.01z"/>
            <path class="fill-black dark:fill-white" d="M13 3a1 1 0 0 1 .117 1.993L13 5H5v14h14v-8a1 1 0 0 1 1.993-.117L21 11v8a2 2 0 0 1-1.85 1.995L19 21H5a2 2 0 0 1-1.995-1.85L3 19V5a2 2 0 0 1 1.85-1.995L5 3zm6.243.343a1 1 0 0 1 1.497 1.32l-.083.095l-9.9 9.899a1 1 0 0 1-1.497-1.32l.083-.094z"/>
        </g>
    </svg>
</button>
  
<div id="edit-command-modal" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative p-4 w-full max-w-md max-h-full">
        <div class="relative bg-white rounded-lg shadow dark:bg-gray-700">
            <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
                    Edit Command: {command.name}
                </h3>
                <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-toggle="edit-command-modal">
                    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                    </svg>
                    <span class="sr-only">Close modal</span>
                </button>
            </div>
            <!-- Modal body -->
            <form class="p-4 md:p-5" method="POST" action="/api/editcommand">
                <div class="grid gap-4 mb-4 grid-cols-2">
                    <div class="col-span-2">
                        <label for="command" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Name</label>
                        <input type="text" name="command" id="name" 
                        class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg 
                        focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-600 
                        dark:border-gray-500 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 
                        dark:focus:border-primary-500" placeholder="Command name" value={command.name} required>
                    </div>
                    <div class="col-span-2">
                        <label for="message" 
                        class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Message</label>
                        <textarea id="message" 
                        name="message" rows="4" 
                        class="block p-2.5 w-full text-sm text-gray-900 bg-gray-50 rounded-lg border 
                        border-gray-300 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-600 
                        dark:border-gray-500 dark:placeholder-gray-400 
                        dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" 
                        placeholder="This is a test of the emergency bot response system!">{command.response}</textarea>                    
                    </div>
                    <div class="col-span-2">
                        <label for="permission-level" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">User Level</label>
                        <select id="permission-level" name="permission-level" 
                        class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg 
                        focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:bg-gray-600 
                        dark:border-gray-500 dark:placeholder-gray-400 dark:text-white 
                        dark:focus:ring-primary-500 dark:focus:border-primary-500" required>
                            { formattedEnums.map(permission => {
                                const lowerCasePerm = permission.toLowerCase()
                                const commandPermLowerCase = command.permission_level.toLowerCase()
                                return lowerCasePerm === commandPermLowerCase ? <option value={permission} selected>{permission}</option> : <option value={permission}>{permission}</option>
                            })
                            }
                        </select>
                    </div>
                    <div class="col-span-2">
                        <label for="cooldown-timer" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Cooldown</label>
                        <input id="edit-cooldown-timer" name="cooldown-timer" type="range" min="5" max="300" value={command.cooldown} step="1" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer dark:bg-gray-800
                        [&::-moz-range-progress]:h-2" required>
                        <output id="edit-cooldown-val"></output>
                    </div>
                </div>
                <button type="submit" class="text-white inline-flex items-center bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
                    Edit Command
                </button>
            </form>
        </div>
    </div>
</div> 

<script>
import { secondsToMinSecs } from '../resources/utils'
const sliderEl = document.querySelector("#edit-cooldown-timer") as HTMLInputElement
if (!sliderEl) {
    throw new Error('Could not find \"#edit-cooldown-timer\" slider.')
}

const cooldownOutput = document.querySelector("#edit-cooldown-val") as HTMLElement
if (!cooldownOutput) {
    throw new Error('Could not find \"#edit-cooldown-val\" output.')
}
cooldownOutput.textContent = secondsToMinSecs(parseInt(sliderEl.value))

sliderEl.addEventListener("input", (event) => {
  const tempSliderValue = (event.currentTarget as HTMLInputElement)?.value
  cooldownOutput.textContent = secondsToMinSecs(parseInt(tempSliderValue))
})
</script>